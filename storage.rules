rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isParticipant(sessionId) {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/sessions/$(sessionId)/participants/$(request.auth.uid)).data.userId == request.auth.uid;
    }

    match /sessions/{sessionId}/{allPaths=**} {
      allow read: if isParticipant(sessionId);
      allow write: if isParticipant(sessionId);
    }

    match /users/{userId}/ai/sessions/{sessionId}/{allPaths=**} {
      allow read: if isParticipant(sessionId);
      allow write: if request.auth.uid == userId;
    }
  }
}
