          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"USER_ID\",\n  \"threadId\": \"thread-1\",\n  \"message\": \"How do I factor x^2 - 5x + 6?\",\n  \"context\": {\n    \"subject\": \"Algebra\"\n  }\n}"
        },
        "url": "{{baseUrl}}/ai/chat/socratic"
