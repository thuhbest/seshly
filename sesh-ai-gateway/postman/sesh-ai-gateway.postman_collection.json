{
  "info": {
    "name": "sesh-ai-gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Sample requests for sesh-ai-gateway"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://sesh-ai-gateway-620223347958.europe-west2.run.app"
    },
    {
      "key": "idToken",
      "value": "YOUR_FIREBASE_ID_TOKEN"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Version",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/version"
      }
    },
    {
      "name": "Policy Gate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{idToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"USER_ID\",\n  \"text\": \"Explain photosynthesis\",\n  \"contextType\": \"practice\"\n}"
        },
        "url": "{{baseUrl}}/ai/policy/gate"
      }
    },
    {
      "name": "Policy Gate (context)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{idToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"USER_ID\",\n  \"text\": \"Explain photosynthesis\",\n  \"contextType\": \"practice\"\n}"
        },
        "url": "{{baseUrl}}/ai/policy/gate/practice"
      }
    },
    {
